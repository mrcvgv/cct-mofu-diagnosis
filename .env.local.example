# ============================================================
# Stripe 設定（.env.local にコピーして値を埋めてください）
# ============================================================

# Stripeダッシュボード > Developers > API keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx

# Stripeダッシュボード > Products で作成した Price ID
# 単発占い ¥490（one_time）
STRIPE_FORTUNE_PRICE_ID=price_xxxxxxxxxxxx

# 住人プラン ¥980/月（recurring）
STRIPE_RESIDENT_PRICE_ID=price_xxxxxxxxxxxx

# 年払い住人プラン ¥9,800/年（recurring）
STRIPE_RESIDENT_YEARLY_PRICE_ID=price_xxxxxxxxxxxx

# Stripeダッシュボード > Webhooks で作成した Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# デプロイURL（Vercelの場合は自動設定されるが明示する）
NEXT_PUBLIC_BASE_URL=https://cct-mofu-diagnosis.vercel.app
